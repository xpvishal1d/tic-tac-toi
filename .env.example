# DigitalOcean: Control Panel → Databases → your cluster → Connection Details
# Use the full "Connection string" (public host for local dev). Keep ?sslmode=require.
# If the password contains @ # / or %, URL-encode it (@ → %40).
DATABASE_URL=postgresql://doadmin:YOUR_PASSWORD@db-postgresql-nyc3-00000.db.ondigitalocean.com:25060/defaultdb?sslmode=require

JWT_SECRET=change-me-to-a-long-random-string
